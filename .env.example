# Supabase（認証＋同期DB）。未設定でもローカル(localStorage)で動作します。
# Supabase ダッシュボード → Project Settings → API Keys から取得。
# Next.js ではクライアントに露出する変数に NEXT_PUBLIC_ 接頭辞が必須。
NEXT_PUBLIC_SUPABASE_URL=
# 新方式の publishable key（sb_publishable_…）を推奨。
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# 旧方式の anon key を使う場合はこちら（どちらか一方でOK。両方あれば publishable 優先）。
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# データパイプライン用。GBIF/Wikidata/MediaWiki へ送る User-Agent に含める連絡先。
# 仕様 §7.2「meaningful な User-Agent」の必須事項。
PIPELINE_CONTACT=skysoyn@gmail.com
