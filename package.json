{
  "name": "fruit-tree",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "フルーツ系統樹トラッカー — 分類階層をたどって食べたフルーツを記録する",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:taxa": "tsx scripts/build-taxa.ts",
    "resolve:taxa": "tsx scripts/resolve.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "fuse.js": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.5"
  }
}
